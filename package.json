{
  "name": "fastplayer-desktop",
  "version": "1.0.1",
  "description": "Fastnet Player desktop client with native player handoff",
  "author": "Fastnet",
  "private": true,
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "vite build",
    "desktop:dev": "electron .",
    "desktop:build": "electron-builder --win nsis"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "laravel-vite-plugin": "^2.0.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "vite": "^7.0.7"
  },
  "dependencies": {
    "framer-motion": "^12.23.24",
    "hls.js": "^1.6.16",
    "lucide-react": "^0.542.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "pe.fastnet.player.desktop",
    "productName": "Fastnet Player Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
